DATABASE_URL="file:./dev.db"

# Signed session cookie secret (required in production)
SESSION_SECRET="change-me-to-a-long-random-string"

# App URL for Stripe redirects, tenant pay links, and Green Button OAuth callback
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe (optional — enable in Settings after adding keys)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Cron secret for scheduled jobs (Authorization: Bearer <CRON_SECRET>)
# POST /api/cron/auto-billing — monthly statement sender
# POST /api/cron/green-button-sync — utility bill import
CRON_SECRET=""

# Green Button Connect My Data — sandbox (works with defaults for local testing)
# Register your redirect URI with the data custodian: {APP_URL}/api/green-button/callback
GREEN_BUTTON_SANDBOX_BASE_URL="https://services.greenbuttondata.org"
GREEN_BUTTON_SANDBOX_CLIENT_ID="third_party"
GREEN_BUTTON_SANDBOX_CLIENT_SECRET="secret"

# Enbridge Gas — set after third-party registration with Enbridge Share My Data
# GREEN_BUTTON_ENBRIDGE_BASE_URL=""
# GREEN_BUTTON_ENBRIDGE_CLIENT_ID=""
# GREEN_BUTTON_ENBRIDGE_CLIENT_SECRET=""

# Alectra Utilities — set after third-party registration
# GREEN_BUTTON_ALECTRA_BASE_URL=""
# GREEN_BUTTON_ALECTRA_CLIENT_ID=""
# GREEN_BUTTON_ALECTRA_CLIENT_SECRET=""
