# Local PostgreSQL via Docker (make db-up) — use the Neon connection string in production
DATABASE_URL="postgresql://rental:rental@localhost:5432/rental_app"

# Signed session cookie secret (required in production, min 32 chars)
SESSION_SECRET="change-me-to-a-long-random-string"

# App URL for Stripe redirects, tenant pay links, and canonical host redirects
# Local: http://localhost:3000 — Production (Railway): https://lessora.ca
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe (optional — enable in Settings after adding keys)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Cron secret for scheduled jobs (Authorization: Bearer <CRON_SECRET>)
# POST /api/cron/auto-billing — monthly statement sender (min 32 chars in production)
CRON_SECRET=""

# Email (production — set RESEND_API_KEY to enable; falls back to console.log in dev)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@lessora.ca"

# Cloudflare R2 file storage (production — falls back to local ./uploads in dev)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""

# DocuSign (optional — enable under Integrations after adding keys)
DOCUSIGN_INTEGRATION_KEY=""
DOCUSIGN_ACCOUNT_ID=""
DOCUSIGN_USER_ID=""
DOCUSIGN_PRIVATE_KEY=""

# Vercel hosted landing only — do not set on local install.
# LOCAL_DATA_ONLY=1 is set automatically on Vercel (no cloud database, no user data).
# ALLOW_CLOUD_DATA=1 opts into cloud persistence on Vercel (not recommended for privacy).
