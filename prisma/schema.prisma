generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String?
  googleId     String?  @unique
  name         String?
  sessionNonce String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  properties      Property[]
  documents       Document[]
  settings        UserSettings?
  utilityProfiles UtilityProfile[]
}

model LoginAttempt {
  id          String    @id @default(cuid())
  key         String    @unique
  count       Int       @default(0)
  lockedUntil DateTime?
  updatedAt   DateTime  @updatedAt
}

model UserSettings {
  id                       String  @id @default(cuid())
  userId                   String  @unique
  landlordName             String?
  paymentInstructions      String?
  statementNotes           String?
  autoSendStatements       Boolean @default(false)
  autoSendDayOfMonth       Int     @default(1)
  leaseReminderDays        Int     @default(30)
  stripePaymentsEnabled Boolean @default(false)
  docusignEnabled         Boolean @default(false)
  user                  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Property {
  id           String   @id @default(cuid())
  userId       String
  name         String
  addressLine1 String
  addressLine2 String?
  city         String
  province     String?
  postalCode   String?
  country      String   @default("Canada")
  notes        String?
  /// Annual municipal property tax (CRA T776 line 9180)
  annualPropertyTaxCents      Int?
  /// Annual property insurance premium (CRA T776 line 9200)
  annualInsurancePremiumCents Int?
  /// Annual mortgage interest paid (CRA T776 line 8710)
  mortgageInterestAnnualCents Int?
  insuranceProvider           String?
  taxRollNumber               String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user                   User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  units                  Unit[]
  utilityBills           UtilityBill[]
  documents              Document[]
  maintenanceRecords MaintenanceRecord[]
  inspections        Inspection[]
}

model Unit {
  id             String   @id @default(cuid())
  propertyId     String
  name           String
  rentAmountCents Int
  rentDueDay     Int      @default(1)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  property           Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenants            Tenant[]
  leases             Lease[]
  utilityRules       UtilityRule[]
  statements         Statement[]
  documents          Document[]
  maintenanceRecords MaintenanceRecord[]
  utilityBillSplits  UtilityBillSplit[]
  inspections        Inspection[]
  leaseDraft         LeaseDraft?
}

model Tenant {
  id                    String    @id @default(cuid())
  unitId                String
  firstName             String
  lastName              String
  email                 String?
  phone                 String?
  moveInDate            DateTime?
  moveOutDate           DateTime?
  emergencyContactName  String?
  emergencyContactPhone String?
  isActive              Boolean   @default(true)
  notes                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  unit       Unit        @relation(fields: [unitId], references: [id], onDelete: Cascade)
  leases     Lease[]
  statements Statement[]
  documents  Document[]
}

model Lease {
  id              String      @id @default(cuid())
  unitId          String
  tenantId        String
  documentId      String?
  leaseStartDate  DateTime
  leaseEndDate    DateTime?
  rentAmountCents Int
  rentDueDay      Int
  status          LeaseStatus @default(active)
  securityDepositCents Int?
  lastMonthRentDeposit Boolean @default(false)
  additionalTerms String?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  unit     Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document Document? @relation(fields: [documentId], references: [id])
}

model UtilityRule {
  id             String      @id @default(cuid())
  unitId         String
  utilityType    UtilityType
  tenantPays     Boolean     @default(true)
  percentage     Float       @default(0)
  includedInRent Boolean     @default(false)
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, utilityType])
}

model UtilityProfile {
  id        String   @id @default(cuid())
  userId    String
  name      String
  /// JSON array of { utilityType, tenantPays, includedInRent, percentage } (String for SQLite compatibility)
  rules     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

model UtilityBill {
  id                      String            @id @default(cuid())
  propertyId              String
  utilityType             UtilityType
  providerName            String?
  amountCents             Int
  billingPeriodStart      DateTime
  billingPeriodEnd        DateTime
  dueDate                 DateTime?
  /// Calendar month/year this bill applies to when generating statements (1–12)
  billMonth               Int?
  billYear                Int?
  documentId              String?
  notes                   String?
  source     UtilityBillSource @default(manual)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  property Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  document Document?            @relation(fields: [documentId], references: [id])
  splits   UtilityBillSplit[]

  @@unique([propertyId, utilityType, billMonth, billYear])
}

model UtilityBillSplit {
  id            String   @id @default(cuid())
  utilityBillId String
  unitId        String
  percentage    Float
  amountCents   Int
  isOverride    Boolean  @default(false)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  utilityBill UtilityBill @relation(fields: [utilityBillId], references: [id], onDelete: Cascade)
  unit        Unit        @relation(fields: [unitId], references: [id], onDelete: Cascade)
}

model Statement {
  id                   String          @id @default(cuid())
  unitId               String
  tenantId             String
  statementNumber      String          @unique
  statementMonth       Int
  statementYear        Int
  issueDate            DateTime
  dueDate              DateTime
  rentAmountCents      Int
  utilityTotalCents    Int             @default(0)
  discountTotalCents   Int             @default(0)
  adjustmentTotalCents Int             @default(0)
  previousBalanceCents Int             @default(0)
  totalDueCents        Int
  status               StatementStatus @default(draft)
  paidAmountCents      Int             @default(0)
  payToken             String?         @unique
  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?
  pdfDocumentId        String?
  emailSentAt          DateTime?
  autoSentAt           DateTime?
  notes                String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  unit      Unit                @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pdfDocument Document?         @relation("StatementPdf", fields: [pdfDocumentId], references: [id])
  lineItems StatementLineItem[]
  payments  Payment[]

  @@unique([unitId, statementMonth, statementYear])
}

model StatementLineItem {
  id                  String              @id @default(cuid())
  statementId         String
  type                StatementLineType
  description         String
  amountCents         Int
  sourceUtilityBillId String?
  sourceDocumentId    String?
  calculationNote     String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  statement Statement @relation(fields: [statementId], references: [id], onDelete: Cascade)
}

model Payment {
  id              String        @id @default(cuid())
  statementId     String
  amountCents     Int
  paymentDate     DateTime
  paymentMethod   PaymentMethod
  referenceNumber String?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  statement Statement @relation(fields: [statementId], references: [id], onDelete: Cascade)
  receipt   Receipt?
}

model Receipt {
  id            String    @id @default(cuid())
  paymentId     String    @unique
  receiptNumber String    @unique
  issueDate     DateTime
  pdfDocumentId String?
  emailSentAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  payment     Payment   @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  pdfDocument Document? @relation("ReceiptPdf", fields: [pdfDocumentId], references: [id])
}

model Document {
  id            String           @id @default(cuid())
  userId        String
  propertyId    String?
  unitId        String?
  tenantId      String?
  category      DocumentCategory
  fileName      String
  filePath      String
  fileMimeType  String
  fileSizeBytes Int
  tags          String?
  ltbFormCode   String?
  sentToTenantAt DateTime?
  docusignEnvelopeId String?  @unique
  signatureStatus    DocumentSignatureStatus @default(none)
  signedAt           DateTime?
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  property          Property?     @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  unit              Unit?         @relation(fields: [unitId], references: [id], onDelete: SetNull)
  tenant            Tenant?       @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  leases            Lease[]
  utilityBills      UtilityBill[]
  statementPdfs     Statement[]   @relation("StatementPdf")
  receiptPdfs       Receipt[]     @relation("ReceiptPdf")
  maintenanceRecord MaintenanceRecord? @relation("MaintenanceInvoice")
  inspectionPhoto   InspectionItemPhoto? @relation("InspectionPhoto")
}

model LeaseDraft {
  id                    String    @id @default(cuid())
  unitId                String    @unique
  firstName             String?
  lastName              String?
  email                 String?
  phone                 String?
  moveInDate            DateTime?
  emergencyContactName  String?
  emergencyContactPhone String?
  leaseStartDate        DateTime?
  leaseEndDate          DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)
}

model Inspection {
  id             String           @id @default(cuid())
  propertyId     String
  unitId         String?
  title          String
  inspectionDate DateTime         @default(now())
  status         InspectionStatus @default(in_progress)
  overallNotes   String?
  completedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  property Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit     Unit?            @relation(fields: [unitId], references: [id], onDelete: SetNull)
  items    InspectionItem[]
}

model InspectionItem {
  id           String               @id @default(cuid())
  inspectionId String
  label        String
  sortOrder    Int
  status       InspectionItemStatus @default(pending)
  notes        String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  inspection Inspection          @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  photos     InspectionItemPhoto[]
}

model InspectionItemPhoto {
  id               String   @id @default(cuid())
  inspectionItemId String
  documentId       String   @unique
  createdAt        DateTime @default(now())

  inspectionItem InspectionItem @relation(fields: [inspectionItemId], references: [id], onDelete: Cascade)
  document       Document       @relation("InspectionPhoto", fields: [documentId], references: [id], onDelete: Cascade)
}

model MaintenanceRecord {
  id                String              @id @default(cuid())
  propertyId        String
  unitId            String?
  category          MaintenanceCategory
  title             String
  description       String?
  vendorName        String?
  costCents         Int?
  maintenanceDate   DateTime?
  status            MaintenanceStatus   @default(planned)
  invoiceDocumentId String?             @unique
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit            Unit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)
  invoiceDocument Document? @relation("MaintenanceInvoice", fields: [invoiceDocumentId], references: [id])
}

enum LeaseStatus {
  active
  expired
  terminated
  draft
}

enum UtilityType {
  gas
  water
  electricity
  internet
  other
}

enum StatementStatus {
  draft
  sent
  partial
  paid
  overdue
  cancelled
}

enum StatementLineType {
  rent
  utility
  discount
  adjustment
  previous_balance
  other
}

enum PaymentMethod {
  e_transfer
  cash
  cheque
  bank_deposit
  stripe
  other
}

enum DocumentCategory {
  lease
  utility_bill
  statement
  receipt
  maintenance_invoice
  maintenance_receipt
  ltb_notice
  tax_report
  notice
  photo
  other
}

enum MaintenanceCategory {
  plumbing
  electrical
  hvac
  appliance
  roof
  pest_control
  cleaning
  general_repair
  other
}

enum MaintenanceStatus {
  planned
  in_progress
  completed
  cancelled
}

enum UtilityBillSource {
  manual
  spreadsheet
}

enum DocumentSignatureStatus {
  none
  pending
  completed
  declined
  voided
}

enum InspectionStatus {
  in_progress
  completed
}

enum InspectionItemStatus {
  pending
  pass
  fail
  na
}
